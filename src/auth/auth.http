@refreshToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIzMzMzNGM5Ni03NDk0LTRiNDctOTE4Yi0yZjI4Njg5ZWI1Y2IiLCJlbWFpbCI6ImJlZ2lubmVyLnVzZXJAZXhhbXBsZS5jb20iLCJyb2xlIjoiQ1VTVE9NRVIiLCJpYXQiOjE3NzY4NjM4NDgsImV4cCI6MTc3NzQ2ODY0OH0.nMy79-Y54WysqhOgJB11AOXpCPBlIfEWEcvB8HRPH4U
@userId = PASTE_USER_ID_HERE

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
	"firstName": "{{firstName}}",
	"lastName": "{{lastName}}",
	"email": "{{email}}",
	"password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
	"email": "{{email}}",
	"password": "{{password}}"
}

### Refresh tokens
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
	"userId": "{{userId}}",
	"refreshToken": "{{refreshToken}}"
}

### Logout (requires valid access token)
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"refreshToken": "{{refreshToken}}"
}
